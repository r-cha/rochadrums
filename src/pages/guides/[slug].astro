---
import "@fontsource/inter/variable.css";
import { getCollection, render } from "astro:content";
import Footer from "~/components/footer.astro";
import Header from "~/components/header.astro";
import "~/styles/index.css";

const { generator, site } = Astro;

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  const getGuidePath = (id: string) => id.replace(/\.(md|mdx)$/, "");

  return guides.map((guide) => ({
    params: {
      slug: getGuidePath(guide.id),
    },
    props: {
      guide,
    },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const canonical = new URL(`/guides/${Astro.params.slug}/`, site);
const title = `${guide.data.title} | rochadrums`;
---

<!DOCTYPE html>
<html lang="en" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={generator} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={guide.data.description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={guide.data.description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={guide.data.description} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Article",
            "headline": guide.data.title,
            "description": guide.data.description,
            "datePublished": guide.data.publishDate,
            "dateModified": guide.data.publishDate,
            "author": {
              "@type": "Person",
              "name": "Robert Chandler",
              "url": site,
            },
            "publisher": {
              "@type": "Person",
              "name": "Robert Chandler",
              "url": site,
            },
            "mainEntityOfPage": String(canonical),
            "url": String(canonical),
            "inLanguage": "en-US",
            "isPartOf": {
              "@type": "CollectionPage",
              "name": "Drum Guides",
              "url": new URL("/guides/", site),
            },
          },
          {
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": site,
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Guides",
                "item": new URL("/guides/", site),
              },
              {
                "@type": "ListItem",
                "position": 3,
                "name": guide.data.title,
                "item": String(canonical),
              },
            ],
          },
        ],
      })}
    />
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <Header />
    <main class="mx-auto max-w-3xl px-8 py-20">
      <h1 class="font-bold tracking-tight text-4xl">{guide.data.title}</h1>
      <p class="mt-4 text-default text-lg">{guide.data.description}</p>
      <article class="guide-content mt-10">
        <Content />
      </article>
    </main>
    <Footer />
  </body>
</html>

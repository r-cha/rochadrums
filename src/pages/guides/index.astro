---
import "@fontsource/inter/variable.css";
import { getCollection } from "astro:content";
import Footer from "~/components/footer.astro";
import Header from "~/components/header.astro";
import "~/styles/index.css";

const { generator, site } = Astro;
const description =
  "Practical drumming guides from Robert Chandler, including beginner setup and gear recommendations.";
const canonical = new URL("/guides/", site);

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order,
);

const getGuidePath = (id: string) => id.replace(/\.(md|mdx)$/, "");
---

<!DOCTYPE html>
<html lang="en" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={generator} />
    <link rel="canonical" href={canonical} />
    <title>Drum Guides | rochadrums</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="Drum Guides | rochadrums" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Drum Guides | rochadrums" />
    <meta name="twitter:description" content={description} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Drum Guides",
        "description": description,
        "url": String(canonical),
        "inLanguage": "en-US",
        "isPartOf": {
          "@type": "WebSite",
          "name": "rochadrums",
          "url": site,
        },
        "mainEntity": {
          "@type": "ItemList",
          "itemListElement": guides.map((guide, index) => ({
            "@type": "ListItem",
            "position": index + 1,
            "url": new URL(`/guides/${getGuidePath(guide.id)}/`, site),
            "name": guide.data.title,
          })),
        },
      })}
    />
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <Header />
    <main class="mx-auto max-w-4xl px-8 py-20">
      <h1 class="font-bold tracking-tight text-4xl">Drum Guides</h1>
      <p class="mt-4 max-w-2xl text-lg text-offset">
        Tutorials, recommendations, and practical notes from my real playing and session workflow.
      </p>

      <ul class="mt-10 grid grid-cols-1 gap-4">
        {
          guides.map((guide) => (
            <li class="flex flex-col items-center gap-4 border border-default bg-offset p-6">
              <h2 class="text-center font-extrabold text-xl">{guide.data.title}</h2>
              <p class="text-center text-offset text-sm">{guide.data.description}</p>
              <a class="inline-flex font-semibold text-secondary" href={`/guides/${getGuidePath(guide.id)}/`}>
                Read guide
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>

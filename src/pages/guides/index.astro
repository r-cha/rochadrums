---
import "@fontsource/inter/variable.css";
import { getCollection } from "astro:content";
import Footer from "~/components/footer.astro";
import "~/styles/index.css";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order,
);

const getGuidePath = (id: string) => id.replace(/\.(md|mdx)$/, "");
---

<!DOCTYPE html>
<html lang="en" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Drum Guides | rochadrums</title>
    <meta
      name="description"
      content="Practical drumming guides from Robert Chandler, including beginner setup and gear recommendations."
    />
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <main class="mx-auto max-w-4xl px-8 py-20">
      <a class="font-semibold text-secondary" href="/">← Back to home</a>
      <h1 class="mt-6 font-bold tracking-tight text-4xl">Drum Guides</h1>
      <p class="mt-4 max-w-2xl text-lg text-offset">
        Tutorials, recommendations, and practical notes from my real playing and session workflow.
      </p>

      <ul class="mt-10 grid grid-cols-1 gap-4">
        {
          guides.map((guide) => (
            <li class="rounded-xl border border-default bg-offset p-6">
              <h2 class="font-bold text-2xl text-default">{guide.data.title}</h2>
              <p class="mt-3 text-offset">{guide.data.description}</p>
              <a class="mt-4 inline-flex font-semibold text-secondary" href={`/guides/${getGuidePath(guide.id)}/`}>
                Read guide
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>

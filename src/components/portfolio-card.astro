---
import { Image } from "astro:assets";
import type { PortfolioLink } from "~/types";

export interface Props {
  site: PortfolioLink;
}

const { site } = Astro.props;

const widths = [450, 800];
const sizes = "(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw";
---

<a
  class="group aspect-square hover:!text-default"
  href={site.url}
  rel="noopener noreferrer"
  aria-label={`Stream ${site.title}`}
>
  <figure class="relative h-full w-full overflow-hidden">
    <Image
      class="object-cover w-full h-full transition-all duration-300 bg-cover group-hover:scale-110 group-focus:scale-110"
      src={site.image}
      widths={widths}
      alt={`Album art of ${site.title}`}
    />
    <figcaption class="sr-only">{site.title} by {site.artist}</figcaption>
  </figure>
</a>
